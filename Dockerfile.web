# ============================================================
# Dockerfile.web -- CAPE Web Interface (Django)
# ============================================================

FROM ubuntu:22.04

ARG CAPE_ROOT=/opt/CAPEv2
ARG DEBIAN_FRONTEND=noninteractive

LABEL description="CAPEv2 Web Interface - Django + Gunicorn"

# -- Timezone --
RUN apt-get update && apt-get install -y tzdata && \
    ln -fs /usr/share/zoneinfo/UTC /etc/localtime && \
    dpkg-reconfigure -f noninteractive tzdata

# -- Lightweight system dependencies --
RUN apt-get update && apt-get install -y \
    python3.10 \
    python3.10-dev \
    python3-pip \
    python3-setuptools \
    git \
    curl \
    libpq-dev \
    libmagic-dev \
    libfuzzy-dev \
    libvirt-dev \
    acl \
    pkg-config \
    postgresql-client \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1 && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.10 1

# -- Create cape user --
RUN groupadd -r cape && \
    useradd -r -g cape -m -s /bin/bash cape

# -- Clone CAPEv2 --
RUN git clone --depth=1 https://github.com/kevoreilly/CAPEv2.git ${CAPE_ROOT} && \
    chown -R cape:cape ${CAPE_ROOT} && \
    sed -i 's/cryptography>=.*/cryptography<46/g' ${CAPE_ROOT}/requirements.txt || true && \
    sed -i 's/cryptography==.*/cryptography<46/g' ${CAPE_ROOT}/requirements.txt || true && \
    sed -i 's/pyasn1==.*/pyasn1<0.6.0/g' ${CAPE_ROOT}/requirements.txt || true && \
    sed -i 's/pyopenssl>=.*/pyopenssl<26/g' ${CAPE_ROOT}/requirements.txt || true && \
    sed -i 's/pyopenssl==.*/pyopenssl<26/g' ${CAPE_ROOT}/requirements.txt || true

# Patch libvirt connection to read-only mode in web interface to avoid permission issues
RUN sed -i 's/conn = libvirt.open(machinery_dsn)/conn = libvirt.openReadOnly(machinery_dsn)/' ${CAPE_ROOT}/web/guac/views.py

# -- Python web dependencies --
WORKDIR ${CAPE_ROOT}

# Remove system-installed pycparser to avoid distutils uninstall errors
RUN apt-get remove -y python3-pycparser || true && \
    rm -rf /usr/lib/python3/dist-packages/pycparser* /usr/lib/python3/dist-packages/_pycparser* || true

# Install poetry and system-level prerequisites
RUN pip3 install --upgrade pip && \
    pip3 install poetry "cryptography<46" "cffi<2.0.0" "pyasn1<0.6.0" "pyopenssl<26" \
        django gunicorn whitenoise djangorestframework django-extensions pyzipper

# Install all CAPE dependencies via poetry to ensure all modules are present (pytz, etc.)
# Falls back to pip if poetry fails
RUN poetry config virtualenvs.create false && \
    poetry install --no-root || \
    (pip3 install "cryptography<46" "cffi<2.0.0" "pyasn1<0.6.0" "pyopenssl<26" && pip3 install -r ${CAPE_ROOT}/requirements.txt)

# Ensure Django and web-specific packages are present
RUN pip3 install django gunicorn whitenoise djangorestframework django-extensions pyzipper psycopg2-binary libvirt-python

# -- Configuration --
RUN mkdir -p /work && chown -R cape:cape /work ${CAPE_ROOT}

COPY scripts/entrypoint-web.sh /entrypoint-web.sh
RUN chmod +x /entrypoint-web.sh

VOLUME ["/work"]

WORKDIR ${CAPE_ROOT}/web

EXPOSE 8000

USER cape
ENTRYPOINT ["/entrypoint-web.sh"]