# Données persistantes
data/
*.log

# Git
.git/
.gitignore

# Environnements Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.env.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# SSL certs
nginx/ssl/

# Docs
*.md
doc/
docs/
