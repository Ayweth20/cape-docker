# CAPEv2 Docker -- .dockerignore
# ============================================================
# Exclude unnecessary files from the build context

# Persistent data
data/
*.log

# Git
.git/
.gitignore

# Python environments
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.env.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# SSL certs
nginx/ssl/

# Docs
*.md
doc/
docs/
