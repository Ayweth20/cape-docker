# ============================================================
# CAPEv2 Docker - Environment Variables
# ============================================================
# Copy this file to .env and update the values for your setup.
#   cp .env.example .env
# ============================================================

# -- Analysis VM Network (KVM) --
CAPE_NETWORK_IFACE=CHANGE_ME
CAPE_NETWORK_SUBNET=1CHANGE_ME/24
CAPE_RESULTSERVER_IP=CHANGE_ME

# -- PostgreSQL --
POSTGRES_USER=cape
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=cape
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432

# -- MongoDB --
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=cape

# -- Redis --
REDIS_HOST=redis
REDIS_PORT=6379

# -- CAPE Web --
CAPE_WEB_PORT=8000
CAPE_SECRET_KEY=CHANGE_ME

# -- CAPE General --
CAPE_USER=root
CAPE_ROOT=/opt/CAPEv2
TZ=UTC

# -- KVM (libvirt connection) --
KVM_DSN=qemu:///system

# -- Analysis VM --
VM1_LABEL=CHANGE_ME
VM1_IP=CHANGE_ME
VM1_SNAPSHOT=CHANGE_ME
VM1_PLATFORM=CHANGE_ME
VM1_ARCH=CHANGE_ME
VM1_TAGS=CHANGE_ME

# -- Persistent Storage --
CAPE_WORK_DIR=./data/cape
POSTGRES_DATA_DIR=./data/postgresql
MONGO_DATA_DIR=./data/mongodb

# -- CAPE Admin User --
CAPE_ADMIN_USER=CHANGE_ME
CAPE_ADMIN_PASSWORD=CHANGE_ME
CAPE_ADMIN_EMAIL=admin@CHANGE_ME.local