# ============================================================
# CAPEv2 Docker - Environment Variables
# ============================================================
# Copy this file to .env and update the values for your setup.
#   cp .env.example .env
# ============================================================

# -- Analysis VM Network (KVM) --
CAPE_NETWORK_IFACE=virbr1
CAPE_NETWORK_SUBNET=192.168.100.0/24
CAPE_RESULTSERVER_IP=192.168.100.1

# -- PostgreSQL --
POSTGRES_USER=cape
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=cape
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432

# -- MongoDB --
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=cape

# -- Redis --
REDIS_HOST=redis
REDIS_PORT=6379

# -- CAPE Web --
CAPE_WEB_PORT=8000
CAPE_SECRET_KEY=CHANGE_ME_generate_a_random_string

# -- CAPE General --
CAPE_USER=root
CAPE_ROOT=/opt/CAPEv2
TZ=UTC

# -- KVM (libvirt connection) --
KVM_DSN=qemu:///system

# -- Analysis VM --
VM1_LABEL=win10
VM1_IP=192.168.100.10
VM1_SNAPSHOT=clean
VM1_PLATFORM=windows
VM1_ARCH=x64
VM1_TAGS=win10

# -- Persistent Storage --
CAPE_WORK_DIR=./data/cape
POSTGRES_DATA_DIR=./data/postgresql
MONGO_DATA_DIR=./data/mongodb
