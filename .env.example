# ============================================================
# CAPEv2 Docker - Variables d'environnement
# ============================================================
# IMPORTANT : Modifiez ces valeurs avant de déployer !

# ---- Réseau des VMs d'analyse (KVM) ----
# Interface réseau libvirt pour les VMs d'analyse (virbr1 par défaut dans cape2.sh)
CAPE_NETWORK_IFACE=virbr1
# Sous-réseau des VMs KVM (doit correspondre à votre réseau libvirt)
CAPE_NETWORK_SUBNET=192.168.122.0/24
# IP du résultserver vue par les VMs (IP du bridge KVM côté host)
CAPE_RESULTSERVER_IP=192.168.122.1

# ---- Base de données PostgreSQL ----
POSTGRES_USER=cape
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=cape
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432

# ---- MongoDB ----
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=cape

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- CAPE Web ----
CAPE_WEB_PORT=8000
# Clé secrète Django (CHANGEZ-LA en production !)
CAPE_SECRET_KEY=CHANGE_ME_random_secret

# ---- CAPE General ----
CAPE_USER=cape
CAPE_ROOT=/opt/CAPEv2
# Timezone
TZ=UTC

# ---- KVM DSN (connexion libvirt) ----
# Pour une connexion locale via socket Unix (monté en volume)
KVM_DSN=qemu:///system

# ---- VM d'analyse (à adapter selon vos VMs KVM) ----
# Nom de la VM dans libvirt
VM1_LABEL=win10
# IP de la VM (doit être dans le réseau CAPE_NETWORK_SUBNET)
VM1_IP=192.168.122.105
# Nom du snapshot à restaurer avant chaque analyse
VM1_SNAPSHOT=cape-snapshot
# Plateforme OS
VM1_PLATFORM=windows
# Architecture
VM1_ARCH=x64
# Tags (doit inclure le tag OS : win10, win7, winxp, win11)
VM1_TAGS=win10

# ---- Stockage persistant ----
# Dossiers sur l'hôte pour les données persistantes (relatifs au répertoire du projet)
CAPE_WORK_DIR=./data/cape
POSTGRES_DATA_DIR=./data/postgresql
MONGO_DATA_DIR=./data/mongodb
